module std from @std()

function fib(n :: int) returns int {
    if n < 2 then return n
    return fib(n - 1) + fib(n - 2)
}

public entry function main() {
    const start_time is std.time.monotonic()
    const result is fib(44)
    const end_time is std.time.monotonic()
    std.io.println("{end_time - start_time}, {result}")
}

