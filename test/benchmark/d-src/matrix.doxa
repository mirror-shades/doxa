module std from @std()

const N is 400

var a :: float[N][N];
var b :: float[N][N];
var c :: float[N][N];

public entry function main() {
    for i while i < N do i++ {
        for j while j < N do j++ {
            a[i][j] is i + j;
            b[i][j] is i - j;
        }
    }

    for i while i < N do i++ {
        for j while j < N do j++ {

            var sum is 0.0;

            for k while k < N do k++ {
                sum += a[i][k] * b[k][j];
            }

            c[i][j] is sum;
        }
    }

    std.io.println("{c[N-1][N-1]}");
}