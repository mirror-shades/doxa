module std from @std()

const N is 400
const REPEATS is 35

var a :: float[N][N];
var b :: float[N][N];
var c :: float[N][N];

public entry function main() {
    for i while i < N do i++ {
        for j while j < N do j++ {
            a[i][j] is i + j;
            b[i][j] is i - j;
        }
    }

    const t0 is std.time.monotonic()

    for r while r < REPEATS do r++ {
        for i while i < N do i++ {
            for j while j < N do j++ {

                var sum is 0.0;

                for k while k < N do k++ {
                    sum += a[i][k] * b[k][j];
                }

                c[i][j] is sum;
            }
        }
    }

    const t1 is std.time.monotonic()

    std.io.println("{t1 - t0}, {c[N-1][N-1]}")
}
