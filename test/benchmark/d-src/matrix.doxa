module std from @std()

const N is 400
const REPEATS is 35

var a :: float[N][N]
var b :: float[N][N]
var c :: float[N][N]

public entry function main() {
    for i while i < N do i++ {
        for j while j < N do j++ {
            a[i][j] is i + j
            b[i][j] is i - j
        }
    }

    # Warm-up: a cheap pass over a and b (the matmul read pattern) before timing.
    var warm is 0.0
    for i while i < N do i++ {
        var s is 0.0
        for k while k < N do k++ {
            s += a[i][k] * b[k][i]
        }
        warm += s
    }

    const t0 is std.time.monotonic()

    var acc is 0.0
    for r while r < REPEATS do r++ {
        a[r % N][r % N] is a[r % N][r % N] + 1.0
        for i while i < N do i++ {
            for j while j < N do j++ {

                var sum is 0.0

                for k while k < N do k++ {
                    sum += a[i][k] * b[k][j]
                }

                c[i][j] is sum
            }
        }
        acc += c[r % N][r % N]
    }

    const t1 is std.time.monotonic()

    const out is acc + warm
    std.io.println("{t1 - t0}, {out}")
}
