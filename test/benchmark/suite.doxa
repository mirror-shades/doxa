module std from @std()

const tests is [
    "fib",
    "sieve",
    "matrix",
    "mb",
]

struct Result {
    public test :: string,
    public runs :: int,
    public time_d :: int,
    public time_c :: int,
    public is_match :: tetra

    function new(test :: string, runs :: int, time_d :: int, time_c :: int, is_match :: tetra) returns Result {
        return $Result {
            test is test,
            runs is runs,
            time_d is time_d,
            time_c is time_c,
            is_match is is_match,
        }
    }
}

var results :: Result[]

function runSuite(runs :: int) {

    std.io.println("Compiling benchmarks...")

    each test in tests {
        std.process.exec("./doxa/bin/doxa compile test/benchmark/d-src/{test}.doxa -o test/benchmark/d-bin/{test}")
        std.process.exec("gcc test/benchmark/c-src/{test}.c -o test/benchmark/c-bin/{test}")
    }

    std.io.println("Running benchmarks...")


    each run in 0 to runs - 1 {
        var time_d is 0
        var time_c is 0
        each test in tests {
            const output_d is timeExec("./test/benchmark/d-bin/{test}", ^time_d)
            const output_c is timeExec("./test/benchmark/c-bin/{test}", ^time_c)
            # var is_match is false
            # if run == 0 then {
            #     is_match is matchOutput(output_c, output_d)
            # }
            # @push(results, Result.new(test, runs, time_d, time_c, is_match))
        }
    }


    # std.io.println("test\t| lang\t| runtime")
    # each result in results {
    #     compare(result)
    # }
}

function compare(result :: Result) {
    const c_total_time is result.time_c / 1000000000
    const d_total_time is result.time_d / 1000000000
    const c_average_time is c_total_time / result.runs
    const d_average_time is d_total_time / result.runs
    std.io.println("--------------------------------")
    std.io.println("{result.test}\t| Doxa\t| {roundTo(d_average_time, 2)}s ( {roundTo(d_total_time, 2)}s / {result.runs} iterations)")
    std.io.println("{result.test}\t| C\t| {roundTo(c_average_time, 2)}s ( {roundTo(c_total_time, 2)}s / {result.runs} iterations)")
    if c_average_time < d_average_time then {
        std.io.println("Doxa is {roundTo(((d_average_time - c_average_time) / c_average_time) * 100, 2)}% slower than C")
    }
    else if c_average_time > d_average_time then {
        std.io.println("Doxa is {roundTo(((c_average_time - d_average_time) / d_average_time) * 100, 2)}% faster than C")
    }
    else {
        std.io.println("Doxa is equal to C")
    }
}

function roundTo(value :: float, precision :: int) returns float {
    const str_value is @string(value)
    var decimal_index is -1
        each char at i in str_value {
            if decimal_index < 0 then {
                if char == "." then decimal_index is i
            }
        }
        if(@length(str_value) < decimal_index + precision + 1) then {
            return @float(str_value)
        }
        return @float(@slice(str_value, 0, decimal_index+precision+1))
}

function matchOutput(c_output :: string, d_output :: string) returns tetra {
    if(c_output != d_output) then {
        const c_len is @length(c_output)
        const d_len is @length(d_output)
        if c_len != d_len then {
            std.io.println("Output length mismatch: c:{c_len} != d:{d_len}")
        }
        each c at i in c_output {
            if c != d_output[i] then {
                std.io.println("Output mismatch at index {i}: c:{c} != d:{d_output[i]}")
            }
        }
        std.io.println("Output mismatch c:{c_output} != d:{d_output}")
        return false
    }
    return true
}

function timeExec(command :: string, ^time :: int) returns string {
    const startTime is std.time.tick()
    const output is std.process.execCapture(command) as string else {
        std.io.println("Error executing command: {command}")
        return ""
    }
    const endTime is std.time.tick()
    time?
    startTime?
    endTime?
    time += (endTime - startTime)
    return output
}

public entry function suite() {
    const args is std.process.args() as string[] else {
        std.io.println("Error getting arguments")
        return
    }
    var runs is 1
    each arg in args {
        if arg == "--long" then {
            runs += 4
        }
    }
    runSuite(runs)
}