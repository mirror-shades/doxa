module std from @std()


const ns_per_s is 1_000_000_000

const tests is [
    # smoke tests
    "fib",
    "sieve",
    "matrix",
    "mb",
    # performance tests
    "arr",
    "call",
    "struct",
    "vec"
]

struct Result {
    public test :: string,
    public runs :: int,
    public time_d :: int,
    public time_c :: int,
    public is_match :: tetra

    function new(test :: string, runs :: int, time_d :: int, time_c :: int, is_match :: tetra) returns Result {
        return $Result {
            test is test,
            runs is runs,
            user_time_d is user_time_d,
            user_time_c is user_time_c,
            kernal_time_d is kernal_time_d,
            kernal_time_c is kernal_time_c,
            is_match is is_match,
        }
    }
}

var results :: Result[]

function runSuite(runs :: int) {

    std.io.println("Compiling benchmarks...")

    each test in tests {
        std.process.exec("./doxa/bin/doxa compile test/benchmark/d-src/{test}.doxa -o test/benchmark/d-bin/{test} --opt=2")
        std.process.exec("gcc test/benchmark/c-src/{test}.c -o test/benchmark/c-bin/{test} -O2")
    }

    std.io.println("Running benchmarks...")

    each test in tests {
        var user_time_d is 0
        var user_time_c is 0
        var time_c is 0
        var is_match is false
        each run in 0 to runs - 1 {
            # user time is measured within timeExec
            # kernal time is returned by the benchmark binary itself
            const output_d is timeExec("./test/benchmark/d-bin/{test}", ^user_time_d)
            const output_c is timeExec("./test/benchmark/c-bin/{test}", ^user_time_c)
            const split_d_output is split(output_d)
            const split_c_output is split(output_c)
            if run == 0 then {
                is_match is matchOutput(split_c_output[1], split_d_output[1])
            }
        }
        @push(results, Result.new(test, runs, user_time_d, user_time_c, split_d_output[0], split_c_output[0], is_match))
    }

    std.io.println("test\t| lang\t| runtime")
    each result in results {
        compare(result)
    }
}

function split(output :: string) returns string[] {
    var result :: string[]
    var current is ""
    each c in output {
        if c == "," then {
            @push(result, current)
            current is ""
        }
        else if c == " " then {}
        else {
            current += c
        }
    }
    @push(result, current)
    return result
}

function compare(result :: Result) {
    const c_total_time is result.time_c / ns_per_s
    const d_total_time is result.time_d / ns_per_s
    const c_average_time is c_total_time / result.runs
    const d_average_time is d_total_time / result.runs
    std.io.println("--------------------------------")
    std.io.println("{result.test}\t| Doxa\t| {roundTo(d_average_time, 2)}s ( {roundTo(d_total_time, 2)}s / {result.runs} iterations)")
    std.io.println("{result.test}\t| C\t| {roundTo(c_average_time, 2)}s ( {roundTo(c_total_time, 2)}s / {result.runs} iterations)")
    if c_average_time < d_average_time then {
        std.io.println("Doxa is {roundTo(((d_average_time - c_average_time) / c_average_time) * 100, 2)}% slower than C")
    }
    else if c_average_time > d_average_time then {
        std.io.println("Doxa is {roundTo(((c_average_time - d_average_time) / d_average_time) * 100, 2)}% faster than C")
    }
    else {
        std.io.println("Doxa is equal to C")
    }
}

function roundTo(value :: float, precision :: int) returns float {
    const str_value is @string(value)
    var decimal_index is -1
        each char at i in str_value {
            if decimal_index < 0 then {
                if char == "." then decimal_index is i
            }
        }
        if(@length(str_value) < decimal_index + precision + 1) then {
            return @float(str_value)
        }
        return @float(@slice(str_value, 0, decimal_index+precision+1))
}

function matchOutput(c_output :: string, d_output :: string) returns tetra {
    if(c_output != d_output) then {
        const c_len is @length(c_output)
        const d_len is @length(d_output)
        if c_len != d_len then {
            std.io.println("Output length mismatch: c:{c_len} != d:{d_len}")
        }
        each c at i in c_output {
            if c != d_output[i] then {
                std.io.println("Output mismatch at index {i}: c:{c} != d:{d_output[i]}")
            }
        }
        std.io.println("Output mismatch c:{c_output} != d:{d_output}")
        return false
    }
    return true
}

function timeExec(command :: string, ^time :: int) returns string {
    const startTime is std.time.tick()
    const output is std.process.execCapture(command) as string else {
        std.io.println("Error executing command: {command}")
        return ""
    }
    const endTime is std.time.tick()
    time += (endTime - startTime)
    return output
}

function writeStats(results :: Result[]) {
    const path is "test/benchmark/stats.csv"
    const header is "test, c_runtime, d_runtime, percentage, delta, date\n"

    if not std.file.exists(path) then {
        std.file.write(path, header)
    }
    each result in results {
        const c_raw is result.time_c / result.runs / ns_per_s
        const d_raw is result.time_d / result.runs / ns_per_s
        const c_time is roundTo(c_raw, 2)
        const d_time is roundTo(d_raw, 2)
        const percentage is roundTo(((d_raw - c_raw) / c_raw) * 100, 2)
        const delta is roundTo(d_raw - c_raw, 2)
        std.file.append(path, "{result.test}, {c_time}, {d_time}, {percentage}, {delta}, {std.time.unix()}\n")
    }
    
}

function prepareEnv() {
    if std.file.IsDir("test/benchmark/d-bin") then {
        const result is std.file.delete("test/benchmark/d-bin", true) as nothing else {
            std.io.println("Failed to remove d-bin: {result}")
            return
        }
    }
    if std.file.IsDir("test/benchmark/c-bin") then {
        const result is std.file.delete("test/benchmark/c-bin", true) as nothing else {
            std.io.println("Failed to remove c-bin: {result}")
            return
        }
    }
    const result_d is std.file.makeDir("test/benchmark/d-bin") as nothing else {
        std.io.println("Failed to create d-bin: {result_d}")
        return
    }
    const result_c is std.file.makeDir("test/benchmark/c-bin") as nothing else {
        std.io.println("Failed to create c-bin: {result_c}")
        return
    }
}

public entry function suite() {
    var runs is 1
    var write is false
    const args is std.process.args() as string[] else {
        std.io.println("Error getting arguments")
        return
    }
    each arg at i in args {
        if arg == "--runs" then {
            runs += @int(args[i+1])
        }
        else if arg == "--write" then {
            write is true
        }
    }
    prepareEnv()
    runSuite(runs)
    if write then {
        writeStats(results)
    }
}