module std from @std()


const ns_per_s is 1_000_000_000

const tests is [
    # smoke tests
    "fib",
    "sieve",
    "matrix",
    "mb",
    # performance tests
    "arr",
    "call",
    "struct",
    "vec"
]

struct CompileStats {
    public c_compile_time :: int[],
    public d_compile_time :: int[],
}

struct Result {
    public test :: string,
    public runs :: int,
    public user_time_d :: int,
    public user_time_c :: int,
    public kernel_time_d :: int,
    public kernel_time_c :: int,
    public is_match :: tetra,
    public compile_stats :: CompileStats,
    function new(test :: string, runs :: int, user_time_d :: int, user_time_c :: int, kernel_time_d :: int, kernel_time_c :: int, is_match :: tetra) returns Result {
        return $Result {
            test is test,
            runs is runs,
            user_time_d is user_time_d,
            user_time_c is user_time_c,
            kernel_time_d is kernel_time_d,
            kernel_time_c is kernel_time_c,
            is_match is is_match,
        }
    }
}

#handle globally because we will reuse the same stats for all results
var compile_stats is $CompileStats {
    c_compile_time is [],
    d_compile_time is [],
}

function runSuite(runs :: int, ^results :: Result[]) {

    std.io.println("Compiling benchmarks...")

    # Compile C with `zig cc` — the exact toolchain Doxa uses internally for
    # .ll -> .o (see main.zig). This shares the same LLVM version and default
    # native -mcpu (e.g. AVX2) as Doxa, avoiding compiler/SIMD-target confounds.
    # -ffp-contract=off stops C from forming FMAs that Doxa's codegen never
    # forms, so floating-point results stay bit-identical between the two.
    # zig cc does not auto-append .exe on Windows, so add it explicitly there.
    var exe_suffix is ""
    if std.host.isWindows() then {
        exe_suffix is ".exe"
    }

    each test in tests {
        const d_compile_start_time is std.time.monotonic()
        std.process.exec("./doxa/bin/doxa compile test/benchmark/d-src/{test}.doxa -o test/benchmark/d-bin/{test} --opt=2")
        const d_compile_end_time is std.time.monotonic()
        @push(compile_stats.d_compile_time, d_compile_end_time - d_compile_start_time)
        const c_compile_start_time is std.time.monotonic()
        std.process.exec("zig cc test/benchmark/c-src/{test}.c -o test/benchmark/c-bin/{test}{exe_suffix} -O2 -ffp-contract=off")
        const c_compile_end_time is std.time.monotonic()
        @push(compile_stats.c_compile_time, c_compile_end_time - c_compile_start_time)
    }

    std.io.println("Running benchmarks...")

    each test in tests {
        # Totals accumulated across runs; averaged at report time.
        var user_time_d is 0
        var user_time_c is 0
        var kernel_time_d is 0
        var kernel_time_c is 0
        var is_match is true
        each run in 0 to runs - 1 {
            # user time: wall time of the whole exec, measured by timeExec
            # kernel time: the elapsed time the benchmark binary reports itself
            const output_d is timeExec("./test/benchmark/d-bin/{test}", ^user_time_d)
            const output_c is timeExec("./test/benchmark/c-bin/{test}", ^user_time_c)
            const split_d_output is split(output_d)
            const split_c_output is split(output_c)
            kernel_time_d += @int(split_d_output[0])
            kernel_time_c += @int(split_c_output[0])
            is_match is is_match and matchOutput(split_c_output[1], split_d_output[1])
        }
        @push(results, Result.new(test, runs, user_time_d, user_time_c, kernel_time_d, kernel_time_c, is_match))
    }
    std.io.println("Completed {runs} runs")
}

function split(output :: string) returns string[] {
    var result :: string[]
    var current is ""
    each c in output {
        if c == "," then {
            @push(result, current)
            current is ""
        }
        else if c == " " then {}
        else {
            current += c
        }
    }
    @push(result, current)
    return result
}

# Convert a total nanosecond count into an average in seconds across runs.
function averageSeconds(total_ns :: int, runs :: int) returns float {
    return @float(total_ns) / @float(ns_per_s) / @float(runs)
}

# Percentage of d relative to the C baseline; guarded against a zero baseline.
function percentVsC(c_value :: float, d_value :: float) returns float {
    if c_value > 0.0 then {
        return ((d_value - c_value) / c_value) * 100
    }
    return 0.0
}

function compare(result :: Result, index :: int) {
    # kernel time is the benchmark's own measured compute time (apples-to-apples)
    const c_compute is averageSeconds(result.kernel_time_c, result.runs)
    const d_compute is averageSeconds(result.kernel_time_d, result.runs)
    # user time only reflects process/runtime overhead outside the measured loop
    const c_overhead is averageSeconds(result.user_time_c - result.kernel_time_c, result.runs)
    const d_overhead is averageSeconds(result.user_time_d - result.kernel_time_d, result.runs)

    const d_compute_pct is percentVsC(c_compute, d_compute)

    # name, matches, doxa runtime, c runtime, +-%, doxa overhead n(%), c overhead n(%), doxa compile time, c compile time, +-%
    @print("{result.test}\t| ")
    @print("match: {result.is_match}\t| ")
    @print("{roundToString(d_compute, 4)}s\t| ")
    @print("{roundToString(c_compute, 4)}s\t| ")
    @print("{roundToString(d_compute_pct, 2)}%   \t| ")
    @print("{roundToString(d_overhead, 4)}s ({roundToString((result.user_time_d - result.kernel_time_d) / result.kernel_time_d * 100, 2)}%)\t| ")
    @print("{roundToString(c_overhead, 4)}s ({roundToString((result.user_time_c - result.kernel_time_c) / result.kernel_time_c * 100, 2)}%)\t| ")
    # compile time is measured once per test (not per run), so convert ns -> s with runs = 1
    const d_compile is averageSeconds(compile_stats.d_compile_time[index], 1)
    const c_compile is averageSeconds(compile_stats.c_compile_time[index], 1)
    @print("{roundToString(d_compile, 4)}s\t| ")
    @print("{roundToString(c_compile, 4)}s\t| ")
    std.io.println("{roundToString(percentVsC(c_compile, d_compile), 2)}%")
}

function roundToString(value :: float, precision :: int) returns string {
    var str_value is @string(value)
    var decimal_index is -1
    each char at i in str_value {
        if decimal_index < 0 then {
            if char == "." then decimal_index is i
        }
    }
    if(@length(str_value) < decimal_index + precision + 1) then {
        const diff is decimal_index + precision + 1 - @length(str_value)
        each i in 0 to diff - 1 {
            str_value += "0"
        }
        return str_value
    }
    # otherwise just slice the string and return the truncated value
    return @slice(str_value, 0, decimal_index+precision+1)
}

function matchOutput(c_output :: string, d_output :: string) returns tetra {
    if(c_output != d_output) then {
        const c_len is @length(c_output)
        const d_len is @length(d_output)
        if c_len != d_len then {
            std.io.println("Output length mismatch: c:{c_len} != d:{d_len}")
        }
        each c at i in c_output {
            if c != d_output[i] then {
                std.io.println("Output mismatch at index {i}: c:{c} != d:{d_output[i]}")
            }
        }
        std.io.println("Output mismatch c:{c_output} != d:{d_output}")
        return false
    }
    return true
}

function timeExec(command :: string, ^time :: int) returns string {
    const startTime is std.time.tick()
    const output is std.process.execCapture(command) as string else {
        std.io.println("Error executing command: {command}")
        return ""
    }
    const endTime is std.time.tick()
    time += (endTime - startTime)
    return output
}

function writeStats(^results :: Result[]) {
    const path is "test/benchmark/stats.csv"
    const header is "test, runs, c_compute, d_compute, c_overhead, d_overhead, compute_pct, compute_delta, date\n"

    if not std.file.exists(path) then {
        std.file.write(path, header)
    }
    each result in results {
        const c_compute is averageSeconds(result.kernel_time_c, result.runs)
        const d_compute is averageSeconds(result.kernel_time_d, result.runs)
        const c_overhead is averageSeconds(result.user_time_c - result.kernel_time_c, result.runs)
        const d_overhead is averageSeconds(result.user_time_d - result.kernel_time_d, result.runs)
        const compute_pct is percentVsC(c_compute, d_compute)
        const compute_delta is d_compute - c_compute
        std.file.append(path, "{result.test}, {result.runs}, {@float(roundToString(c_compute, 4))}, {@float(roundToString(d_compute, 4))}, {@float(roundToString(c_overhead, 4))}, {@float(roundToString(d_overhead, 4))}, {@float(roundToString(compute_pct, 2))}, {@float(roundToString(compute_delta, 4))}, {std.time.unix()}\n")
    }

}

function prepareEnv() {
    if std.file.IsDir("test/benchmark/d-bin") then {
        const result is std.file.delete("test/benchmark/d-bin", true) as nothing else {
            std.io.println("Failed to remove d-bin: {result}")
            return
        }
    }
    if std.file.IsDir("test/benchmark/c-bin") then {
        const result is std.file.delete("test/benchmark/c-bin", true) as nothing else {
            std.io.println("Failed to remove c-bin: {result}")
            return
        }
    }
    const result_d is std.file.makeDir("test/benchmark/d-bin") as nothing else {
        std.io.println("Failed to create d-bin: {result_d}")
        return
    }
    const result_c is std.file.makeDir("test/benchmark/c-bin") as nothing else {
        std.io.println("Failed to create c-bin: {result_c}")
        return
    }
}

function printResults(^results :: Result[]) {
    std.io.println("test\t| matches\t| doxa runtime\t| c runtime\t| runtime %\t| doxa overhead\t\t| c overhead\t\t| doxa compile\t| c compile\t| compile %")
    std.io.println("---------------------------------------------------------------------------------------------------------------------------------------------------------------")
    each result at index in results {
        compare(result, index)
    }
}

public entry function suite() {
    var runs is 1
    var write is false
    var results :: Result[]

    const args is std.process.args() as string[] else {
        std.io.println("Error getting arguments")
        return
    }
    each arg at i in args {
        if arg == "--runs" then {
            if i + 1 < @length(args) then {
                runs is @int(args[i+1])
            }
        }
        else if arg == "--write" then {
            write is true
        }
    }
    prepareEnv()
    runSuite(runs, ^results)
    printResults(^results)
    if write then {
        writeStats(^results)
    }
}
