pub function findString(collection :: string, value :: string) returns int {
    return @find(collection, value)
}

pub function findInt(collection :: int[], value :: int) returns int {
    return @find(collection, value)
}

pub function findFloat(collection :: float[], value :: float) returns int {
    return @find(collection, value)
