module error from "../error/error.doxa"

zig Parse {
    const std = @import("std");

    fn parseIntSafe(text: []const u8) i64 {
        return std.fmt.parseInt(i64, text, 0) catch 0;
    }

    fn isInt(text: []const u8) bool {
        _ = std.fmt.parseInt(i64, text, 0) catch return false;
        return true;
    }

    fn parseFloatSafe(text: []const u8) f64 {
        return std.fmt.parseFloat(f64, text) catch 0.0;
    }

    fn isFloat(text: []const u8) bool {
        _ = std.fmt.parseFloat(f64, text) catch return false;
        return true;
    }

    fn parseByteSafe(text: []const u8) u8 {
        return std.fmt.parseInt(u8, text, 0) catch 0;
    }

    fn isByte(text: []const u8) bool {
        _ = std.fmt.parseInt(u8, text, 0) catch return false;
        return true;
    }
}

function outOfBounds(index :: int, length :: int) returns tetra {
    if index < 0 then return true
    if index >= length then return true
    return false
}

function sliceOutOfBounds(start :: int, length :: int, total :: int) returns tetra {
    if start < 0 then return true
    if length < 0 then return true
    if start > total then return true
    if start + length > total then return true
    return false
}

pub function pushString(^collection :: string, value :: string) {
    @push(collection, value)
}

pub function pushInt(^collection :: int[], value :: int) {
    @push(collection, value)
}

pub function pushFloat(^collection :: float[], value :: float) {
    @push(collection, value)
}

pub function pushByte(^collection :: byte[], value :: byte) {
    @push(collection, value)
}

pub function pushTetra(^collection :: tetra[], value :: tetra) {
    @push(collection, value)
}

pub function pushStringArray(^collection :: string[], value :: string) {
    @push(collection, value)
}

pub function popString(^collection :: string) returns string | error.Method {
    if @length(collection) == 0 then return error.Method.EmptyCollection
    return @pop(collection)
}

pub function popInt(^collection :: int[]) returns int | error.Method {
    if @length(collection) == 0 then return error.Method.EmptyCollection
    return @pop(collection)
}

pub function popFloat(^collection :: float[]) returns float | error.Method {
    if @length(collection) == 0 then return error.Method.EmptyCollection
    return @pop(collection)
}

pub function popByte(^collection :: byte[]) returns byte | error.Method {
    if @length(collection) == 0 then return error.Method.EmptyCollection
    return @pop(collection)
}

pub function popTetra(^collection :: tetra[]) returns tetra | error.Method {
    if @length(collection) == 0 then return error.Method.EmptyCollection
    return @pop(collection)
}

pub function popStringArray(^collection :: string[]) returns string | error.Method {
    if @length(collection) == 0 then return error.Method.EmptyCollection
    return @pop(collection)
}

pub function insertString(^collection :: string, index :: int, value :: string) returns error.Method {
    const len is @length(collection)
    if index < 0 then return error.Method.OutOfBounds
    if index > len then return error.Method.OutOfBounds
    @insert(collection, index, value)
}

pub function insertInt(^collection :: int[], index :: int, value :: int) returns error.Method {
    const len is @length(collection)
    if index < 0 then return error.Method.OutOfBounds
    if index > len then return error.Method.OutOfBounds
    @insert(collection, index, value)
}

pub function insertFloat(^collection :: float[], index :: int, value :: float) returns error.Method {
    const len is @length(collection)
    if index < 0 then return error.Method.OutOfBounds
    if index > len then return error.Method.OutOfBounds
    @insert(collection, index, value)
}

pub function insertByte(^collection :: byte[], index :: int, value :: byte) returns error.Method {
    const len is @length(collection)
    if index < 0 then return error.Method.OutOfBounds
    if index > len then return error.Method.OutOfBounds
    @insert(collection, index, value)
}

pub function insertTetra(^collection :: tetra[], index :: int, value :: tetra) returns error.Method {
    const len is @length(collection)
    if index < 0 then return error.Method.OutOfBounds
