    const len is @length(collection)
    if outOfBounds(index, len) then return error.Method.OutOfBounds
    return @remove(collection, index)
}

pub function removeByte(^collection :: byte[], index :: int) returns byte | error.Method {
    const len is @length(collection)
    if outOfBounds(index, len) then return error.Method.OutOfBounds
    return @remove(collection, index)
}

pub function removeTetra(^collection :: tetra[], index :: int) returns tetra | error.Method {
