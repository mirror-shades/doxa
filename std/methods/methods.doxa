pub function sliceString(collection :: string, start :: int, length :: int) returns string | error.Method {
    if sliceOutOfBounds(start, length, @length(collection)) then return error.Method.OutOfBounds
    return @slice(collection, start, length)
}

pub function sliceInt(collection :: int[], start :: int, length :: int) returns int[] | error.Method {
    if sliceOutOfBounds(start, length, @length(collection)) then return error.Method.OutOfBounds
    return @slice(collection, start, length)
}

pub function sliceFloat(collection :: float[], start :: int, length :: int) returns float[] | error.Method {
    if sliceOutOfBounds(start, length, @length(collection)) then return error.Method.OutOfBounds
    return @slice(collection, start, length)
}

pub function sliceByte(collection :: byte[], start :: int, length :: int) returns byte[] | error.Method {
    if sliceOutOfBounds(start, length, @length(collection)) then return error.Method.OutOfBounds
    return @slice(collection, start, length)
}

pub function sliceTetra(collection :: tetra[], start :: int, length :: int) returns tetra[] | error.Method {
    if sliceOutOfBounds(start, length, @length(collection)) then return error.Method.OutOfBounds
    return @slice(collection, start, length)
}

pub function sliceStringArray(collection :: string[], start :: int, length :: int) returns string[] | error.Method {
    if sliceOutOfBounds(start, length, @length(collection)) then return error.Method.OutOfBounds
    return @slice(collection, start, length)
}

pub function toInt(value :: int | float | byte | string) returns int | error.Method {
    value as int then {
        return value
    }
    value as byte then {
        return @int(value)
    }
    value as float then {
        if value != value then return error.Method.InvalidNumber
        if value > 9223372036854775807.0 then return error.Method.Overflow
        if value < -9223372036854775808.0 then return error.Method.Overflow
        return @int(value)
    }
    value as string then {
        if Parse.isInt(value) then return Parse.parseIntSafe(value)
        return error.Method.InvalidNumber
    }
    return error.Method.Unexpected
}

pub function toFloat(value :: int | float | byte | string) returns float | error.Method {
    value as float then {
        if value != value then return error.Method.InvalidNumber
        return value
    }
    value as int then {
        return @float(value)
    }
    value as byte then {
        return @float(value)
    }
    value as string then {
        if Parse.isFloat(value) then return Parse.parseFloatSafe(value)
        return error.Method.InvalidNumber
    }
    return error.Method.Unexpected
}

pub function toByte(value :: int | float | byte | string) returns byte | error.Method {
    value as byte then {
        return value
    }
    value as int then {
        if value < 0 or value > 255 then return error.Method.Overflow
        return @byte(value)
    }
    value as float then {
        if value != value then return error.Method.InvalidNumber
        if value < 0.0 or value > 255.0 then return error.Method.Overflow
        return @byte(value)
    }
    value as string then {
        if Parse.isByte(value) then return Parse.parseByteSafe(value)
        return error.Method.InvalidNumber
    }
    return error.Method.Unexpected
}
