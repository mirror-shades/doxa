zig Host {
    const builtin = @import("builtin");

    fn osName() []const u8 {
        return @tagName(builtin.os.tag);
    }

    fn archName() []const u8 {
        return @tagName(builtin.cpu.arch);
    }

    fn abiName() []const u8 {
        return @tagName(builtin.abi);
    }

    fn isWindows() bool {
        return builtin.os.tag == .windows;
    }

    fn isLinux() bool {
        return builtin.os.tag == .linux;
    }

    fn isMac() bool {
        return builtin.os.tag == .macos;
    }
}

public function os() returns string {
    return Host.osName();
}

public function arch() returns string {
    return Host.archName();
}

public function abi() returns string {
    return Host.abiName();
}

public function isWindows() returns tetra {
    return Host.isWindows();
}

public function isLinux() returns tetra {
    return Host.isLinux();
}

public function isMac() returns tetra {
    return Host.isMac();
}
